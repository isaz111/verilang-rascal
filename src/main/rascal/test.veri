defmodule Set
using List
defspace Bool end
defspace Set end
defspace Element end
defspace Estudiante < Set end
defoperator union : Set -> Set -> Set end
defoperator isIn : Element -> Set -> Bool end
defvar p : Bool , q : Bool end
defvar x : Set , y : Set , z : Set end
defexpression forall x in Set . x = x end
defexpression x = y and y = z end
end
