defmodule Set
using List
defspace Persona end
defspace Estudiante < Persona end
defoperator union : Set -> Set -> Set end
defoperator isIn : Element -> Set -> Bool end
defvar p : Bool , q : Bool end
defrule (implication p q) -> (disjunction (negation p) q) end
defexpression forall x in Persona . x = x end
defexpression exists y in Persona . y = y end
defexpression neg (x = y) end
defexpression x = y and y = z end
defequation x = y end
end
